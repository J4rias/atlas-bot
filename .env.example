# Server
PORT=3001
NODE_ENV=development

# ERP API
ERP_BASE_URL=http://localhost:3000
ERP_API_TOKEN=

# Database (PostgreSQL + pgvector)
DATABASE_URL=postgresql://atlas:password@localhost:5432/atlas_bot

# Anthropic API
ANTHROPIC_API_KEY=

# Z.ai API (GLM models — OpenAI-compatible)
ZAI_API_KEY=

# OpenAI API (embeddings only — text-embedding-3-small)
OPENAI_API_KEY=

# Mode 1: Consultant (Messenger)
META_VERIFY_TOKEN=
META_PAGE_ACCESS_TOKEN=
META_APP_SECRET=

# Mode 2: Manager (Telegram)
TELEGRAM_BOT_TOKEN=
# Recipients: comma-separated Telegram chat IDs per role
MANAGER_BOSS_CHATS=
MANAGER_TECH_CHATS=
