# Mode 1: Consultant (Messenger)
META_VERIFY_TOKEN=
META_PAGE_ACCESS_TOKEN=
META_APP_SECRET=

# Mode 2: Manager (Telegram)
TELEGRAM_BOT_TOKEN=
